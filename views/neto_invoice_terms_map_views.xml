<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="neto_invoice_terms_map_view_list" model="ir.ui.view">
        <field name="name">neto.invoice.terms.map.list</field>
        <field name="model">neto.invoice.terms.map</field>
        <field name="arch" type="xml">
            <list string="Neto Invoice Terms Maps">
                <field name="active"/>
                <field name="store_id"/>
                <field name="neto_invoice_terms"/>
                <field name="payment_term_id"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="neto_invoice_terms_map_view_form" model="ir.ui.view">
        <field name="name">neto.invoice.terms.map.form</field>
        <field name="model">neto.invoice.terms.map</field>
        <field name="arch" type="xml">
            <form string="Neto Invoice Terms Map">
                <sheet>
                    <group>
                        <group string="Neto">
                            <field name="active"/>
                            <field name="store_id"/>
                            <field name="neto_invoice_terms"/>
                        </group>
                        <group string="Odoo">
                            <field name="payment_term_id"/>
                            <field name="note"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="neto_invoice_terms_map_action" model="ir.actions.act_window">
        <field name="name">Invoice Terms Maps</field>
        <field name="res_model">neto.invoice.terms.map</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
