<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wizard: Sync Single Order (order ID only) -->
    <record id="neto_sync_wizard_view_form_single" model="ir.ui.view">
        <field name="name">neto.sync.wizard.form.single</field>
        <field name="model">neto.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Sync Single Neto Order">
                <group>
                    <field name="store_id"/>
                    <field name="order_id_input"
                           string="Neto Order ID"
                           placeholder="e.g. GLE39259 or LIA36217"/>
                    <field name="import_as_history"
                           string="Import As History (No Accounting)"/>
                    <field name="force_resync"
                           string="Force Re-sync"
                           help="Tick this if the order already exists in Odoo. 
                                 It will patch Date Paid, Payment Method and Delivery Address 
                                 from the latest Neto data without creating a duplicate."/>
                </group>
                <footer>
                    <button name="action_sync_order"
                            string="Sync Order"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="neto_sync_wizard_action_single" model="ir.actions.act_window">
        <field name="name">Sync Single Order</field>
        <field name="res_model">neto.sync.wizard</field>
        <field name="view_id" ref="neto_sync_wizard_view_form_single"/>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Wizard: Run Sync Now (date range only) -->
    <record id="neto_sync_wizard_view_form_range" model="ir.ui.view">
        <field name="name">neto.sync.wizard.form.range</field>
        <field name="model">neto.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Run Neto Sync">
                <group>
                    <field name="store_id"/>
                    <field name="date_from" widget="datetime"
                           string="From"
                           placeholder="From date/time (UTC)"/>
                    <field name="date_to" widget="datetime"
                           string="To"
                           placeholder="To date/time (UTC) — leave blank for now"/>
                    <field name="import_as_history"/>
                </group>
                <footer>
                    <button name="action_sync_order"
                            string="Run Sync"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="neto_sync_wizard_action" model="ir.actions.act_window">
        <field name="name">Run Sync Now</field>
        <field name="res_model">neto.sync.wizard</field>
        <field name="view_id" ref="neto_sync_wizard_view_form_range"/>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="neto_sync_wizard_view_form_history_queue" model="ir.ui.view">
        <field name="name">neto.sync.wizard.form.history.queue</field>
        <field name="model">neto.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Queue Neto History Import">
                <group>
                    <field name="store_id"/>
                    <field name="date_from" widget="datetime"
                           string="From"
                           placeholder="From date/time (UTC)"/>
                    <field name="date_to" widget="datetime"
                           string="To"
                           placeholder="To date/time (UTC)"/>
                    <field name="chunk_days"/>
                    <field name="queue_orders"/>
                    <field name="queue_payments"/>
                    <field name="queue_rmas"/>
                    <field name="import_as_history"/>
                </group>
                <footer>
                    <button name="action_queue_history_import"
                            string="Queue Background Jobs"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="neto_sync_wizard_action_history_queue" model="ir.actions.act_window">
        <field name="name">Queue History Import</field>
        <field name="res_model">neto.sync.wizard</field>
        <field name="view_id" ref="neto_sync_wizard_view_form_history_queue"/>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_import_as_history': True, 'default_chunk_days': 7}</field>
    </record>

</odoo>
