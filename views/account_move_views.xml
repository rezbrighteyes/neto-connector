<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_view_form_neto_rma" model="ir.ui.view">
        <field name="name">account.move.form.neto.rma</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="neto_rma_id" readonly="1" invisible="not neto_rma_id" widget="badge" decoration-info="neto_rma_id != False" string="Neto RMA"/>
                <field name="neto_rma_status" readonly="1" invisible="not neto_rma_status" widget="badge" string=""/>
            </xpath>
        </field>
    </record>
</odoo>