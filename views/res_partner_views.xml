<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_partner_view_form_neto" model="ir.ui.view">
        <field name="name">res.partner.form.neto</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Neto" name="neto_tab">
                    <div class="alert alert-warning" invisible="not neto_on_credit_hold">
                        &#9888;&#65039; This customer is on credit hold in Neto.
                    </div>
                    <group string="Neto Identity">
                        <field name="neto_username" readonly="1"/>
                        <field name="neto_classification"/>
                    </group>
                    <group string="Credit (from Neto)">
                        <field name="neto_account_balance" readonly="1"/>
                        <field name="neto_available_credit" readonly="1"/>
                        <field name="credit_limit"/>
                        <field name="neto_on_credit_hold"/>
                    </group>
                    <group string="Terms &amp; Manager">
                        <field name="property_payment_term_id"/>
                        <field name="user_id" string="Sales Representative"/>
                        <field name="neto_last_sync" readonly="1"/>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
