<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="neto_payment_view_list" model="ir.ui.view">
        <field name="name">neto.payment.list</field>
        <field name="model">neto.payment</field>
        <field name="arch" type="xml">
            <list string="Neto Payments" create="0">
                <field name="date_paid"/>
                <field name="neto_payment_id"/>
                <field name="neto_order_id"/>
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="store_id"/>
                <field name="amount_paid"/>
                <field name="currency_code" optional="show"/>
                <field name="payment_method_name"/>
                <field name="days_to_pay"/>
                <field name="is_late"/>
                <field name="is_orphan_payment"/>
            </list>
        </field>
    </record>

    <record id="neto_payment_view_form" model="ir.ui.view">
        <field name="name">neto.payment.form</field>
        <field name="model">neto.payment</field>
        <field name="arch" type="xml">
            <form string="Neto Payment" create="0">
                <sheet>
                    <group>
                        <group string="Neto">
                            <field name="neto_payment_id"/>
                            <field name="neto_order_id"/>
                            <field name="store_id"/>
                            <field name="company_id"/>
                            <field name="currency_code"/>
                        </group>
                        <group string="Payment">
                            <field name="amount_paid"/>
                            <field name="currency_id"/>
                            <field name="date_paid"/>
                            <field name="payment_method"/>
                            <field name="payment_method_name"/>
                            <field name="process_by"/>
                        </group>
                        <group string="Odoo Link">
                            <field name="sale_order_id"/>
                            <field name="partner_id"/>
                            <field name="days_to_pay"/>
                            <field name="is_late"/>
                            <field name="is_orphan_payment"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="payment_notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="neto_payment_view_search" model="ir.ui.view">
        <field name="name">neto.payment.search</field>
        <field name="model">neto.payment</field>
        <field name="arch" type="xml">
            <search string="Neto Payments">
                <field name="neto_payment_id"/>
                <field name="neto_order_id"/>
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="store_id"/>
                <filter name="orphan" string="Orphan" domain="[('is_orphan_payment', '=', True)]"/>
                <filter name="late" string="Late" domain="[('is_late', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_store" string="Store" context="{'group_by': 'store_id'}"/>
                    <filter name="group_method" string="Payment Method" context="{'group_by': 'payment_method_name'}"/>
                    <filter name="group_month" string="Date Paid" context="{'group_by': 'date_paid:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="neto_payment_action" model="ir.actions.act_window">
        <field name="name">Neto Payments</field>
        <field name="res_model">neto.payment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="neto_payment_view_search"/>
    </record>

</odoo>
