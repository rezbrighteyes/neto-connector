<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Server action: Run Sync Now (last 7 days) — ALL stores -->
    <record id="neto_run_sync_action" model="ir.actions.server">
        <field name="name">Run Neto Sync Now</field>
        <field name="model_id" ref="model_neto_sync_log"/>
        <field name="state">code</field>
        <field name="code">
env['neto.connector'].run_sync(hours_back=168)
action = {
    'type': 'ir.actions.client',
    'tag': 'display_notification',
    'params': {
        'title': 'Neto Sync',
        'message': 'Sync completed (last 7 days). Check the Sync Log for results.',
        'type': 'success',
        'sticky': False,
    },
}
        </field>
    </record>

    <!-- Action: open Settings -->
    <record id="neto_settings_action" model="ir.actions.act_window">
        <field name="name">Neto Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{"module": "Reza_neto_connector"}</field>
    </record>

    <!-- Top-level menu -->
    <menuitem id="menu_neto_sync_root"
              name="Neto Sync"
              sequence="100"/>

    <!-- Sub-menus -->
    <menuitem id="menu_neto_stores"
              name="Stores"
              parent="menu_neto_sync_root"
              action="neto_store_action"
              sequence="5"/>

    <menuitem id="menu_neto_sync_log"
              name="Sync Log"
              parent="menu_neto_sync_root"
              action="neto_sync_log_action"
              sequence="10"/>

    <menuitem id="menu_neto_run_sync"
              name="Run Sync Now"
              parent="menu_neto_sync_root"
              action="neto_run_sync_action"
              sequence="20"/>

    <!-- Sync Single Order — admin only -->
    <menuitem id="menu_neto_sync_single_order"
              name="Sync Single Order"
              parent="menu_neto_sync_root"
              action="neto_sync_wizard_action"
              groups="base.group_system"
              sequence="25"/>

    <menuitem id="menu_neto_settings"
              name="Settings"
              parent="menu_neto_sync_root"
              action="neto_settings_action"
              sequence="30"/>

</odoo>
