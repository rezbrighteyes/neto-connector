<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action: open Settings -->
    <record id="neto_settings_action" model="ir.actions.act_window">
        <field name="name">Neto Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{"module": "Reza_neto_connector"}</field>
    </record>

    <!-- Top-level menu -->
    <menuitem id="menu_neto_sync_root"
              name="Neto Sync"
              sequence="100"/>

    <!-- Sub-menus -->
    <menuitem id="menu_neto_stores"
              name="Stores"
              parent="menu_neto_sync_root"
              action="neto_store_action"
              sequence="5"/>

    <menuitem id="menu_neto_sync_log"
              name="Sync Log"
              parent="menu_neto_sync_root"
              action="neto_sync_log_action"
              sequence="10"/>

    <menuitem id="menu_neto_product_sync_log"
              name="Product Sync Log"
              parent="menu_neto_sync_root"
              action="neto_product_sync_log_action"
              sequence="12"/>

    <menuitem id="menu_neto_payments"
              name="Payments"
              parent="menu_neto_sync_root"
              action="neto_payment_action"
              sequence="14"/>

    <menuitem id="menu_neto_price_maps"
              name="Price Maps"
              parent="menu_neto_sync_root"
              action="neto_price_map_action"
              sequence="13"/>

    <menuitem id="menu_neto_invoice_terms_maps"
              name="Invoice Terms Maps"
              parent="menu_neto_sync_root"
              action="neto_invoice_terms_map_action"
              sequence="16"/>

    <!-- Run Sync Now: opens date-range wizard -->
    <menuitem id="menu_neto_run_sync"
              name="Run Sync Now"
              parent="menu_neto_sync_root"
              action="neto_sync_wizard_action"
              sequence="20"/>

    <!-- Sync Single Order: opens single-order wizard (admin only) -->
    <menuitem id="menu_neto_sync_single_order"
              name="Sync Single Order"
              parent="menu_neto_sync_root"
              action="neto_sync_wizard_action_single"
              groups="base.group_system"
              sequence="25"/>

    <menuitem id="menu_neto_shipping_audit"
              name="Shipping Data Audit"
              parent="menu_neto_sync_root"
              action="neto_shipping_audit_wizard_action"
              groups="base.group_system"
              sequence="27"/>

    <menuitem id="menu_neto_settings"
              name="Settings"
              parent="menu_neto_sync_root"
              action="neto_settings_action"
              sequence="30"/>

    <menuitem id="menu_neto_rma_log" name="RMA Log" parent="menu_neto_sync_root" action="Reza_neto_connector.neto_rma_log_action" sequence="15"/>
</odoo>
