<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="neto_price_map_view_list" model="ir.ui.view">
        <field name="name">neto.price.map.list</field>
        <field name="model">neto.price.map</field>
        <field name="arch" type="xml">
            <list string="Neto Price Maps">
                <field name="active"/>
                <field name="store_id"/>
                <field name="pricelist_id"/>
                <field name="inventory_id"/>
                <field name="range_name"/>
                <field name="description"/>
                <field name="unit_price"/>
                <field name="rrp"/>
                <field name="file"/>
                <field name="sheet"/>
            </list>
        </field>
    </record>

    <record id="neto_price_map_view_form" model="ir.ui.view">
        <field name="name">neto.price.map.form</field>
        <field name="model">neto.price.map</field>
        <field name="arch" type="xml">
            <form string="Neto Price Map">
                <sheet>
                    <group>
                        <group string="Routing">
                            <field name="active"/>
                            <field name="store_id"/>
                            <field name="company_id" readonly="1"/>
                            <field name="pricelist_id"/>
                        </group>
                        <group string="Imported Values">
                            <field name="inventory_id"/>
                            <field name="range_name"/>
                            <field name="description"/>
                            <field name="unit_price"/>
                            <field name="rrp"/>
                        </group>
                    </group>
                    <group string="Source">
                        <group>
                            <field name="file"/>
                            <field name="sheet"/>
                        </group>
                        <group>
                            <field name="note"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="neto_price_map_action" model="ir.actions.act_window">
        <field name="name">Price Maps</field>
        <field name="res_model">neto.price.map</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Import Neto price mapping rows here.
            </p>
            <p>
                You can import the extracted pricing CSV directly. The sync will
                prefer these imported unit prices and RRPs over connector fallback logic.
            </p>
        </field>
    </record>

</odoo>
