<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="neto_product_link_view_list" model="ir.ui.view">
        <field name="name">neto.product.link.list</field>
        <field name="model">neto.product.link</field>
        <field name="arch" type="xml">
            <list string="Neto Product Links"
                  decoration-muted="not is_active">
                <field name="store_id"/>
                <field name="company_id" optional="show"/>
                <field name="product_id"/>
                <field name="neto_sku"/>
                <field name="neto_product_id"/>
                <field name="neto_barcode"/>
                <field name="available_sell_quantity"/>
                <field name="is_active"/>
                <field name="last_sync_date"/>
                <field name="last_sync_note" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="neto_product_link_view_form" model="ir.ui.view">
        <field name="name">neto.product.link.form</field>
        <field name="model">neto.product.link</field>
        <field name="arch" type="xml">
            <form string="Neto Product Link">
                <sheet>
                    <group>
                        <group string="Identity">
                            <field name="store_id"/>
                            <field name="company_id"/>
                            <field name="product_id"/>
                            <field name="neto_product_id"/>
                            <field name="neto_sku"/>
                            <field name="neto_reference_number"/>
                        </group>
                        <group string="Status">
                            <field name="is_active"/>
                            <field name="neto_approved"/>
                            <field name="neto_virtual"/>
                            <field name="neto_is_variant"/>
                            <field name="neto_parent_sku"/>
                            <field name="available_sell_quantity"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Details" name="neto_details">
                            <group>
                                <group string="Naming">
                                    <field name="neto_name"/>
                                    <field name="neto_subtitle"/>
                                    <field name="neto_brand"/>
                                    <field name="neto_model"/>
                                    <field name="neto_categories"/>
                                    <field name="neto_specifications"/>
                                </group>
                                <group string="Barcodes">
                                    <field name="neto_barcode"/>
                                    <field name="neto_generic_barcode"/>
                                </group>
                            </group>
                            <group>
                                <group string="Pricing (reference only)">
                                    <field name="neto_default_price"/>
                                    <field name="neto_rrp"/>
                                    <field name="neto_cost_price"/>
                                    <field name="neto_purchase_price"/>
                                    <field name="neto_promotion_price"/>
                                    <field name="neto_tax_inclusive"/>
                                </group>
                                <group string="Logistics">
                                    <field name="neto_shipping_weight"/>
                                    <field name="neto_shipping_height"/>
                                    <field name="neto_shipping_width"/>
                                    <field name="neto_shipping_length"/>
                                    <field name="neto_cubic_weight"/>
                                </group>
                            </group>
                            <group>
                                <group string="Supply">
                                    <field name="neto_primary_supplier"/>
                                    <field name="neto_supplier_item_code"/>
                                </group>
                                <group string="Audit">
                                    <field name="neto_date_added"/>
                                    <field name="neto_date_updated"/>
                                    <field name="last_sync_date"/>
                                </group>
                            </group>
                        </page>
                        <page string="Content" name="neto_content">
                            <group>
                                <field name="neto_seo_page_title"/>
                                <field name="neto_seo_meta_description" widget="text"/>
                                <field name="neto_search_keywords" widget="text"/>
                            </group>
                            <separator string="Short Description"/>
                            <field name="neto_short_description"/>
                            <separator string="Description"/>
                            <field name="neto_description"/>
                        </page>
                        <page string="Raw Data" name="neto_raw">
                            <group>
                                <field name="neto_price_groups_json" widget="text"/>
                                <field name="warehouse_quantity_json" widget="text"/>
                                <field name="last_sync_note" widget="text"/>
                            </group>
                            <separator string="Verbatim GetItem response"/>
                            <field name="neto_raw_json" widget="text" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="neto_product_link_action" model="ir.actions.act_window">
        <field name="name">Product Links</field>
        <field name="res_model">neto.product.link</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Neto product links yet.
            </p>
            <p>
                Product sync creates one link per Neto store and Odoo product.
            </p>
        </field>
    </record>

</odoo>
