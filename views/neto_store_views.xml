<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="neto_store_view_list" model="ir.ui.view">
        <field name="name">neto.store.list</field>
        <field name="model">neto.store</field>
        <field name="arch" type="xml">
            <list string="Neto Stores">
                <field name="name"/>
                <field name="company_id"/>
                <field name="warehouse_id"/>
                <field name="store_url"/>
                <field name="last_sync_date"/>
                <field name="last_product_sync_date" optional="show"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="neto_store_view_form" model="ir.ui.view">
        <field name="name">neto.store.form</field>
        <field name="model">neto.store</field>
        <field name="arch" type="xml">
            <form string="Neto Store">
                <sheet>
                    <group>
                        <group string="Connection">
                            <field name="name"/>
                            <field name="store_url" placeholder="https://yourstore.neto.com.au"/>
                            <field name="api_key" password="True"/>
                            <field name="active"/>
                        </group>
                        <group string="Odoo Routing">
                            <field name="company_id"/>
                            <field name="warehouse_id"/>
                            <field name="neto_default_categ_id"/>
                        </group>
                        <group string="Sync Status">
                            <field name="last_sync_date"/>
                            <field name="last_product_sync_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="neto_store_action" model="ir.actions.act_window">
        <field name="name">Neto Stores</field>
        <field name="res_model">neto.store</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
