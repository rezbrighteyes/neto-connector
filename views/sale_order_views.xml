<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form view: Neto badges in header + fields in Other Info tab -->
    <record id="sale_order_view_form_neto" model="ir.ui.view">
        <field name="name">sale.order.form.neto</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Neto badges inside the header statusbar, before the status buttons -->
            <xpath expr="//header" position="inside">
                <field name="neto_order_id"
                       readonly="1"
                       invisible="not neto_order_id"
                       widget="badge"
                       decoration-info="neto_order_id != False"
                       string="Neto Order"/>
                <field name="neto_order_status"
                       readonly="1"
                       invisible="not neto_order_status"
                       widget="badge"
                       decoration-success="neto_order_status == 'Pick'"
                       decoration-warning="neto_order_status == 'New'"
                       decoration-danger="neto_order_status == 'Cancelled'"
                       string=""/>
            </xpath>
            <!-- Neto fields in Other Info tab for reference -->
            <group name="sales_person" position="inside">
                <field name="neto_order_id" readonly="1" string="Neto Order ID"/>
                <field name="neto_order_status" readonly="1" string="Neto Status"/>
            </group>
        </field>
    </record>

    <!-- List view: add Neto Order ID column after the order number -->
    <record id="sale_order_view_list_neto" model="ir.ui.view">
        <field name="name">sale.order.list.neto</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="neto_order_id"
                       string="Neto Order"
                       optional="show"
                       readonly="1"/>
            </xpath>
        </field>
    </record>

</odoo>
