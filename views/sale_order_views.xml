<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form view: Neto badges in header + fields in Other Info tab -->
    <record id="sale_order_view_form_neto" model="ir.ui.view">
        <field name="name">sale.order.form.neto</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Neto badges inside the header statusbar -->
            <xpath expr="//header" position="inside">
                <field name="neto_history_import" invisible="1"/>

                <!-- Neto Order ID badge (always blue when present) -->
                <field name="neto_order_id"
                       readonly="1"
                       invisible="not neto_order_id"
                       widget="badge"
                       decoration-info="neto_order_id != False"
                       string="Neto Order"/>

                <!-- Neto Status badge — colour driven by computed neto_status_decoration -->
                <field name="neto_status_decoration" invisible="1"/>
                <field name="neto_order_status"
                       readonly="1"
                       invisible="not neto_order_status"
                       widget="badge"
                       decoration-success="neto_status_decoration == 'success'"
                       decoration-info="neto_status_decoration == 'info'"
                       decoration-warning="neto_status_decoration == 'warning'"
                       decoration-danger="neto_status_decoration == 'danger'"
                       string=""/>

                <!--
                    Internal order badge.
                    Boolean fields cannot use widget=badge in Odoo 18 — they render
                    as a checkbox. We use the computed Char neto_internal_label instead
                    ('Internal' when True, empty string when False).
                -->
                <field name="neto_internal_label"
                       readonly="1"
                       invisible="not neto_internal_label"
                       widget="badge"
                       decoration-warning="neto_internal_label == 'Internal'"
                       string=""/>

                <button name="action_print_neto_history_tax_invoice"
                        type="object"
                        string="Historical Tax Invoice"
                        class="btn-secondary"
                        invisible="not neto_history_import or not neto_order_id"/>

            </xpath>

            <!-- Neto fields in Other Info tab -->
            <group name="sales_person" position="inside">
                <field name="neto_order_id"        readonly="1" string="Neto Order ID"/>
                <field name="neto_order_status"    readonly="1" string="Neto Status"/>
                <field name="neto_internal"         readonly="1" string="Internal Order"/>
                <field name="neto_date_paid"        readonly="1" string="Date Paid"
                       invisible="not neto_date_paid"/>
                <field name="neto_payment_method"  readonly="1" string="Payment Method"
                       invisible="not neto_payment_method"/>
            </group>
        </field>
    </record>

    <!-- List view: Neto Order ID, Status, Internal flag, Date Paid, Payment Method -->
    <record id="sale_order_view_list_neto" model="ir.ui.view">
        <field name="name">sale.order.list.neto</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="neto_order_id"
                       string="Neto Order"
                       optional="show"
                       readonly="1"/>
                <field name="neto_order_status"
                       string="Neto Status"
                       optional="show"
                       readonly="1"/>
                <field name="neto_internal"
                       string="Internal"
                       optional="hide"
                       readonly="1"/>
                <field name="date_order"
                       string="Order Date"
                       optional="show"
                       readonly="1"/>
                <field name="neto_date_paid"
                       string="Date Paid"
                       optional="show"
                       readonly="1"/>
                <field name="neto_payment_method"
                       string="Payment Method"
                       optional="show"
                       readonly="1"/>
            </xpath>
        </field>
    </record>

</odoo>
