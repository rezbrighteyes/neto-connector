<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ir_cron_neto_sync" model="ir.cron">
        <field name="name">Neto: Sync Wholesale Orders</field>
        <field name="model_id" ref="model_neto_sync_log"/>
        <field name="state">code</field>
        <field name="code">env['neto.connector'].run_sync()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>

    <record id="ir_cron_neto_product_sync" model="ir.cron">
        <field name="name">Neto: Sync Active Products</field>
        <field name="model_id" ref="model_neto_product_sync_log"/>
        <field name="state">code</field>
        <field name="code">env['neto.connector'].run_product_sync()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="False"/>
    </record>

    <record id="ir_cron_neto_product_stock_sync" model="ir.cron">
        <field name="name">Neto: Sync Product Stock Quantities</field>
        <field name="model_id" ref="model_neto_product_sync_log"/>
        <field name="state">code</field>
        <field name="code">env['neto.connector'].run_product_stock_sync()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="False"/>
    </record>

    <record id="ir_cron_neto_history_import_jobs" model="ir.cron">
        <field name="name">Neto: Process Queued History Imports</field>
        <field name="model_id" ref="model_neto_history_import_job"/>
        <field name="state">code</field>
        <field name="code">env['neto.history.import.job'].cron_process_pending_history_import_jobs(limit=10)</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
